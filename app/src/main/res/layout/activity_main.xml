<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- 🏘️ Títulos principales -->
    <TextView
        android:id="@+id/tv_titulo_principal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Junta de Condominio Karuai"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_subtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Torre A1"
        android:textSize="18sp"
        android:textStyle="italic"
        android:layout_marginBottom="32dp" />

    <!-- 🚀 Botón para abrir la Activity de Consulta -->
    <Button
        android:id="@+id/btnConsulta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Consultar Aptos"
        />

    <!-- 🔧 Otro botón para futura función -->
    <Button
        android:id="@+id/btnPizarra"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mostrar Pizarra"
        android:layout_marginTop="16dp"
        />

    <!-- 🔄 ProgressBar centrado -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="gone"/>
</LinearLayout>